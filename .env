# =====================================================================
#  automated-videostreaming – environment configuration
#  Copy this file to ".env" (Docker Compose only auto-loads ".env"):
#     cp .env.example .env      # or:  cp env .env
# =====================================================================

# --- AirVPN (WireGuard) ---
# Get these from the AirVPN "Config Generator" (WireGuard).
WG_PRIVATE_KEY=
WG_PSK=
# IMPORTANT: include the full address, e.g. 10.5.79.2/32 (NOT just /32)
WG_ADDRESS=10.5.79.2/32
WG_SERVER_COUNTRY=United Kingdom

# --- Ports ---
QBIT_WEBUI_PORT=8080
# NOTE: SABnzbd's WebUI defaults to 8080 internally. Because it shares the
# gluetun network namespace with qBittorrent, set SABnzbd's internal port to
# this value on first launch (Config -> General -> Web Server) to avoid a clash.
SABNZBD_PORT=8085
VPN_TORRENT_PORT=34753
SONARR_WEBUI_PORT=8989
RADARR_WEBUI_PORT=7878
PROWLARR_WEBUI_PORT=9696
FLARESOLVER_WEBUI_PORT=8191
LIDARR_WEBUI_PORT=8686
SEERR_WEBUI_PORT=5055

# --- Timezone ---
TZ=Europe/Amsterdam
